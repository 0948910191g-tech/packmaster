                  <div className=\{`bg-white p-20 rounded-[3rem] border-2 transition-all duration-300 shadow-xl shadow-blue-900/5 $\{loadingStatus.active ? 'border-blue-200 bg-blue-50/30' : 'border-blue-50 hover:border-blue-100'\}`\}>\
