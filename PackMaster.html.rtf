                    ) : (\
                      <div className="text-center py-4">\
                        <div className="w-24 h-24 bg-blue-50/80 rounded-3xl flex items-center justify-center mx-auto mb-8 border border-blue-100/50 text-4xl shadow-sm">\uc0\u9729 \u65039 </div>\
