                      <button onClick=\{handleExportRules\} className="bg-white border-2 border-blue-50 text-blue-950 hover:border-blue-100 hover:bg-blue-50/30 px-5 py-3 rounded-2xl text-sm font-bold transition-all flex items-center gap-2 shadow-sm"><span>\uc0\u55357 \u56510 </span> \u3626 \u3635 \u3619 \u3629 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 </button>\
                    </div>\
                  </div>\
                  \
                  <div className="bg-white rounded-[2.5rem] shadow-xl shadow-blue-900/5 border-2 border-blue-50 overflow-hidden mb-10">\
                    <div className="p-10 border-b-2 border-blue-50 bg-blue-50/20">\
                      <form onSubmit=\{(e) => \{ e.preventDefault(); if (!newRule.keyword.trim() || !newRule.shortName.trim()) return; setSkuRules([\{ ...newRule, id: Date.now() \}, ...skuRules]); setNewRule(\{ keyword: '', shortName: '' \}); showToast('\uc0\u3648 \u3614 \u3636 \u3656 \u3617 \u3585 \u3598 \u3651 \u3627 \u3617 \u3656 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 ', 'success'); \}\} className="flex flex-col md:flex-row gap-6 items-end">\
                        <div className="flex-1 w-full"><label className="block text-[11px] font-black text-blue-950/50 mb-3 uppercase tracking-widest pl-2">1. \uc0\u3588 \u3635 \u3607 \u3637 \u3656 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3588 \u3657 \u3609 \u3627 \u3634  (Keyword)</label><input type="text" value=\{newRule.keyword\} onChange=\{(e) => setNewRule(\{...newRule, keyword: e.target.value\})\} placeholder="\u3648 \u3594 \u3656 \u3609  baby Wipes 10" className="w-full border-2 border-blue-100 bg-white px-6 py-4 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-900 outline-none transition-all text-base font-bold text-blue-950" /></div>\
                        <div className="flex-1 w-full"><label className="block text-[11px] font-black text-blue-950/50 mb-3 uppercase tracking-widest pl-2">2. \uc0\u3594 \u3639 \u3656 \u3629 \u3618 \u3656 \u3629 \u3607 \u3637 \u3656 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619  (1 \u3594 \u3636 \u3657 \u3609 )</label><input type="text" value=\{newRule.shortName\} onChange=\{(e) => setNewRule(\{...newRule, shortName: e.target.value\})\} placeholder="\u3648 \u3594 \u3656 \u3609  \u3648 \u3604 \u3657 \u3591 \u3617 \u3656 \u3623 \u3591  10" className="w-full border-2 border-blue-100 bg-white px-6 py-4 rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-900 outline-none transition-all text-base font-bold text-blue-950" /></div>\
                        <button type="submit" disabled=\{!newRule.keyword || !newRule.shortName\} className="bg-blue-950 hover:bg-blue-900 disabled:opacity-50 text-white px-8 py-4 rounded-2xl font-bold transition-all shadow-lg shadow-blue-900/20 h-[60px] flex items-center gap-2 active:scale-95"><span>\uc0\u10133 </span> \u3648 \u3614 \u3636 \u3656 \u3617 </button>\
                      </form>\
                    </div>\
                    <div className="max-h-[400px] overflow-y-auto">\
                        <table className="w-full text-left">\
                        <thead><tr className="text-blue-950/40 text-[10px] font-black uppercase tracking-widest bg-blue-50/30 border-b-2 border-blue-50"><th className="px-10 py-5">No.</th><th className="px-10 py-5">Keyword</th><th className="px-10 py-5">Base SKU</th><th className="px-10 py-5 text-right"></th></tr></thead>\
                        <tbody className="divide-y-2 divide-blue-50/50">\{skuRules.map((rule, idx) => (<tr key=\{rule.id\} className="bg-white hover:bg-blue-50/40 transition-colors group"><td className="px-10 py-5 text-sm font-black text-blue-950/30">\{idx + 1\}</td><td className="px-10 py-5 font-mono text-[15px] font-bold text-blue-950/80">\{rule.keyword\}</td><td className="px-10 py-5"><span className="text-blue-900 font-black text-[15px] bg-blue-100/50 border border-blue-200/50 px-4 py-1.5 rounded-xl">\{rule.shortName\}</span></td><td className="px-10 py-5 text-right"><button onClick=\{() => setSkuRules(skuRules.filter(r => r.id !== rule.id))\} className="text-blue-950/20 hover:text-red-500 hover:bg-red-50 p-2.5 rounded-xl transition-all"><span>\uc0\u55357 \u56785 \u65039 </span></button></td></tr>))\}\
                        \{skuRules.length === 0 && <tr><td colSpan="4" className="p-24 text-center text-blue-950/30 text-sm font-bold">\uc0\u3652 \u3617 \u3656 \u3617 \u3637 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3588 \u3621 \u3633 \u3591 \u3588 \u3635 \u3624 \u3633 \u3614 \u3607 \u3660 </td></tr>\}\
                        </tbody>\
                        </table>\
                    </div>\
                  </div>\
\
                  <div className="bg-white border-2 border-blue-50 p-10 rounded-[2.5rem] shadow-xl shadow-blue-900/5 relative overflow-hidden">\
                    <div className="relative z-10">\
                      <h3 className="text-xl font-black mb-6 flex items-center gap-3 text-blue-950"><span>\uc0\u55358 \u56814 </span> \u3607 \u3604 \u3626 \u3629 \u3610 \u3619 \u3632 \u3610 \u3610 \u3588 \u3635 \u3609 \u3623 \u3603 \u3618 \u3629 \u3604 </h3>\
                      <div className="flex flex-col md:flex-row gap-5 mb-8">\
                          <input type="text" value=\{testInput\} onChange=\{(e) => setTestInput(e.target.value)\} placeholder="\uc0\u3623 \u3634 \u3591 \u3594 \u3639 \u3656 \u3629 \u3626 \u3636 \u3609 \u3588 \u3657 \u3634 \u3648 \u3605 \u3655 \u3617 \u3654  \u3648 \u3614 \u3639 \u3656 \u3629 \u3607 \u3604 \u3626 \u3629 \u3610 ..." className="flex-1 border-2 border-blue-100 px-6 py-4 rounded-2xl outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-900 text-base font-bold text-blue-950 placeholder:text-blue-950/30 transition-all" />\
                          <div className="flex items-center gap-4 border-2 border-blue-100 px-5 py-3 rounded-2xl bg-blue-50/30"><span className="text-[11px] font-black text-blue-500 uppercase tracking-widest">QTY</span><input type="number" min="1" value=\{testQty\} onChange=\{(e) => setTestQty(e.target.value)\} className="w-16 bg-transparent outline-none text-blue-950 text-center text-xl font-black" /></div>\
                      </div>\
                      <div className="bg-blue-50/50 border-2 border-blue-100 p-8 rounded-3xl flex items-center justify-between">\
                        <span className="text-blue-950/40 font-black text-[11px] uppercase tracking-widest">Result</span>\
                        \{testInput ? (testResult !== '\uc0\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3605 \u3633 \u3657 \u3591 \u3594 \u3639 \u3656 \u3629  (\u3648 \u3614 \u3636 \u3656 \u3617 \u3585 \u3598  SKU)' && testResult !== '\u3652 \u3617 \u3656 \u3614 \u3610 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 ' ? (<div className="flex items-center gap-4"><span className="text-4xl font-black text-blue-950 tracking-tight">\{testResult\}</span></div>) : (<div className="flex items-center gap-2"><span className="text-sm font-bold text-red-500 bg-red-50 px-4 py-2 rounded-xl">\u3652 \u3617 \u3656 \u3614 \u3610 \u3588 \u3637 \u3618 \u3660 \u3648 \u3623 \u3636 \u3619 \u3660 \u3604 </span></div>)) : <span className="text-4xl font-black text-blue-950/10">-</span>\}\
                      </div>\
                    </div>\
                  </div>\
                </div>\
              )\}\
\
              \{activeTab === 'preview' && (\
                <div className="p-12 max-w-[1400px] mx-auto animate-in fade-in slide-in-from-bottom-8 duration-500">\
                  <div className="flex flex-col xl:flex-row justify-between items-center mb-12 gap-8">\
                    <div className="text-center xl:text-left"><h2 className="text-4xl font-black text-blue-950 mb-2 tracking-tight">\uc0\u3619 \u3637 \u3623 \u3636 \u3623 \u3649 \u3621 \u3632 \u3614 \u3636 \u3617 \u3614 \u3660 </h2><p className="text-blue-950/60 text-base font-semibold">\u3605 \u3619 \u3623 \u3592 \u3626 \u3629 \u3610 \u3588 \u3623 \u3634 \u3617 \u3606 \u3641 \u3585 \u3605 \u3657 \u3629 \u3591  \{orders.length\} \u3619 \u3634 \u3618 \u3585 \u3634 \u3619 </p></div>\
                    <div className="flex flex-wrap justify-center items-center gap-4">\
                       <div className="bg-white border-2 border-blue-50 p-1.5 rounded-2xl flex gap-1 mr-2 shadow-sm">\
                         <button onClick=\{() => setPreviewMode('table')\} className=\{`px-6 py-2.5 rounded-[12px] font-bold text-sm transition-all $\{previewMode === 'table' ? 'bg-blue-50 text-blue-900 shadow-sm border border-blue-100' : 'text-blue-950/50 hover:text-blue-900 border border-transparent'\}`\}>\uc0\u3605 \u3634 \u3619 \u3634 \u3591 \u3626 \u3619 \u3640 \u3611 </button>\
                         <button onClick=\{() => setPreviewMode('labels')\} className=\{`px-6 py-2.5 rounded-[12px] font-bold text-sm transition-all $\{previewMode === 'labels' ? 'bg-blue-50 text-blue-900 shadow-sm border border-blue-100' : 'text-blue-950/50 hover:text-blue-900 border border-transparent'\}`\}>\uc0\u3651 \u3610 \u3611 \u3632 \u3627 \u3609 \u3657 \u3634 </button>\
                       </div>\
                       <button onClick=\{() => \{ setOrders([]); showToast('\uc0\u3621 \u3657 \u3634 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592 '); \}\} disabled=\{orders.length === 0\} className="bg-white border-2 border-blue-50 hover:bg-red-50 hover:border-red-100 hover:text-red-600 text-blue-950/60 disabled:opacity-50 px-5 py-3 rounded-2xl font-bold text-sm shadow-sm flex items-center gap-2 transition-all"><span>\u55357 \u56580 </span> \u3621 \u3657 \u3634 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 </button>\
                       <button onClick=\{handleExportPDF\} disabled=\{exportStatus.active || orders.length === 0\} className="bg-white border-2 border-blue-50 hover:border-blue-100 disabled:opacity-50 text-blue-900 px-6 py-3 rounded-2xl font-bold text-sm shadow-sm flex items-center gap-2 transition-all active:scale-95"><span>\uc0\u55357 \u56549 </span> Save PDF</button>\
                       <button onClick=\{() => window.print()\} disabled=\{orders.length === 0\} className="bg-blue-950 hover:bg-blue-900 disabled:opacity-50 text-white px-8 py-3 rounded-2xl font-bold text-sm shadow-lg shadow-blue-900/20 flex items-center gap-2 transition-all active:scale-95"><span>\uc0\u55357 \u56744 \u65039 </span> \u3614 \u3636 \u3617 \u3614 \u3660 </button>\
                    </div>\
                  </div>\
\
                  \{orders.length === 0 ? (\
                    <div className="bg-white p-32 rounded-[3rem] text-center border-2 border-blue-50 flex flex-col items-center justify-center shadow-sm">\
                      <span className="text-6xl mb-6 opacity-30">\uc0\u55357 \u56516 </span><h3 className="font-black text-2xl text-blue-950/30">\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3617 \u3637 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3614 \u3636 \u3617 \u3614 \u3660 </h3><p className="text-blue-950/30 text-sm mt-2 font-medium">\u3650 \u3611 \u3619 \u3604 \u3629 \u3633 \u3611 \u3650 \u3627 \u3621 \u3604 \u3652 \u3615 \u3621 \u3660 \u3651 \u3609 \u3648 \u3617 \u3609 \u3641 \u3649 \u3619 \u3585 </p>\
                    </div>\
                  ) : previewMode === 'table' ? (\
                    <div className="bg-white rounded-[2.5rem] shadow-xl shadow-blue-900/5 overflow-hidden no-print border-2 border-blue-50">\
                      <table className="w-full text-left">\
                        <thead><tr className="bg-blue-50/50 text-blue-950/50 uppercase tracking-widest text-[10px] font-black border-b-2 border-blue-50"><th className="px-10 py-6">Tracking</th><th className="px-10 py-6 text-center">Qty</th><th className="px-10 py-6">Output Label</th></tr></thead>\
                        <tbody className="divide-y-2 divide-blue-50/50">\{MappedOrders.map((order) => (<tr key=\{order.id\} className="hover:bg-blue-50/30 transition-colors"><td className="px-10 py-6 font-mono text-[15px] font-bold text-blue-950/60">\{order.tracking\}</td><td className="px-10 py-6 text-center font-black text-2xl text-blue-950/40">x\{order.originalQty\}</td><td className="px-10 py-6"><span className=\{`font-black text-2xl px-5 py-2 rounded-xl inline-block $\{order.shortName.includes('\uc0\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3605 \u3633 \u3657 \u3591 \u3594 \u3639 \u3656 \u3629 ') ? 'text-red-500 bg-red-50' : 'text-blue-900 bg-blue-100/50'\}`\}>\{order.shortName\}</span></td></tr>))\}</tbody>\
                      </table>\
                    </div>\
                  ) : (\
                    <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10 justify-items-center pb-20 no-print">\
                      \{MappedOrders.map((order) => (<div key=\{`prev-$\{order.id\}`\} className="transform hover:scale-[1.01] transition-transform duration-200"><LabelCard order=\{order\} /></div>))\}\
                    </div>\
                  )\}\
                </div>\
              )\}\
            </main>\
          </div>\
\
          <div className="fixed pointer-events-none" style=\{\{ top: 0, left: '-9999px', width: '100mm', zIndex: -100 \}\}>\
            \{MappedOrders.map((order) => (\
              <div key=\{`render-arena-$\{order.id\}`\} id=\{`render-target-$\{order.id\}`\} style=\{\{ position: 'relative', width: '100mm', height: '150mm', backgroundColor: 'white' \}\}>\
                <LabelCard order=\{order\} isExport=\{true\} />\
              </div>\
            ))\}\
          </div>\
          <div className="hidden print-area w-full text-black">\
            \{MappedOrders.map((order) => (<LabelCard key=\{`print-$\{order.id\}`\} order=\{order\} isExport=\{true\} />))\}\
          </div>\
        </div>\
      );\
    \}\
\
    const root = ReactDOM.createRoot(document.getElementById('root'));\
    root.render(<App />);\
  </script>\
</body>\
</html>}